    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:MauiAppHotel.Views"
    Title="MauiAppHotel">

    <TabBar>
        <Tab Title="Hospedagem">
            <ShellContent ContentTemplate="{DataTemplate views:ContratacaoHospedagem}" />
        </Tab>
        <Tab Title="Sobre">
            <ShellContent ContentTemplate="{DataTemplate views:Sobre}" />
        </Tab>
    </TabBar>
</Shell>