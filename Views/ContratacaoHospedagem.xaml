<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:sys="clr-namespace:System;assembly=netstandard"
             x:Class="MauiAppHotel.Views.ContratacaoHospedagem"
             Title="Reserva">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFF9C4" Offset="0.1" />
            <GradientStop Color="#FBC02D" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20">
            <Label Text="Golden Palace Hotel" 
                   FontSize="28" 
                   FontAttributes="Bold" 
                   TextColor="#424242"
                   HorizontalOptions="Center" />

            <Border StrokeShape="RoundRectangle 15" Stroke="#F9A825" Padding="20" BackgroundColor="White">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Quantidade de Adultos:" FontAttributes="Bold" TextColor="#424242" />
                    <HorizontalStackLayout Spacing="10">
                        <Stepper x:Name="stp_adultos" Minimum="1" Maximum="10" />
                        <Label Text="{Binding Source={x:Reference stp_adultos}, Path=Value}" 
                               FontSize="20" VerticalOptions="Center" TextColor="#424242" />
                    </HorizontalStackLayout>

                    <Label Text="Data de Check-in:" FontAttributes="Bold" TextColor="#424242" />
                    <DatePicker x:Name="dtp_checkin" 
                                Format="dd/MM/yyyy" 
                                MinimumDate="{x:Static sys:DateTime.Now}" />

                    <Label Text="Tipo de Acomodação:" FontAttributes="Bold" TextColor="#424242" />
                    <Picker x:Name="pck_suite" Title="Selecione">
                        <Picker.Items>
                            <x:String>Econômica</x:String>
                            <x:String>Luxo</x:String>
                            <x:String>Presidencial</x:String>
                        </Picker.Items>
                    </Picker>
                </VerticalStackLayout>
            </Border>

            <Button Text="Verificar Disponibilidade" 
                    BackgroundColor="#F9A825" 
                    TextColor="Black" 
                    FontAttributes="Bold" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>